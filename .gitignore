# Python virtual environment
venv/
__pycache__/
*.pyc

# Runtime data — uploaded originals, working/annotated copies, OCR cache
uploads/
outputs/

# Server state
.server.pid

# Environment / secrets — never commit
.env
.env.*
*.env

# Test run artifacts (the test_*.py scripts are tracked; their output is not)
tests/auto/*.png
tests/auto/*.log

# PDFs — input documents and generated samples are not tracked.
# Remove this line if you want a sample PDF committed.
*.pdf
# ...but the compiled LaTeX report is a deliverable and IS tracked.
!docs/report/annot8-report.pdf

# LaTeX build artifacts
*.aux
*.toc
docs/report/*.log
docs/report/*.out

# macOS
.DS_Store
